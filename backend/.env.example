# LLM API Keys
OPENROUTER_API_KEY=your_openrouter_key
GROQ_API_KEY=your_groq_key

# Retrieval API Keys
TAVILY_API_KEY=your_tavily_key
OPENALEX_API_KEY=your_openalex_key_optional

# Vector Database (Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_if_cloud

# Per-Agent Model Configuration
# Use OpenRouter model IDs (e.g., "anthropic/claude-3-sonnet") 
# or Groq model IDs (e.g., "llama-3.3-70b-versatile")
DEFAULT_MODEL=llama-3.3-70b-versatile
CLARIFICATION_MODEL=llama-3.1-8b-instant
PLANNING_MODEL=llama-3.1-8b-instant
RETRIEVAL_MODEL=llama-3.1-8b-instant
SYNTHESIS_MODEL=llama-3.1-70b-versatile
WRITING_MODEL=anthropic/claude-3.5-sonnet
CRITIC_MODEL=anthropic/claude-3.5-sonnet
REFINEMENT_MODEL=llama-3.3-70b-versatile

# Optional: Embedding Model (Mistral Embed produces 1024 dimensions)
OPENALEX_API_KEY=
EMBEDDING_MODEL=mistralai/mistral-embed-2312
# OPENAI_API_KEY=not_needed_if_using_openrouter_embeddings
